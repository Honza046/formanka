# PIN pro přístup do kuchyně (/pizza/kuchyne)
KITCHEN_PIN=1234

# Tajný klíč pro session token (v produkci změňte!)
KITCHEN_SECRET=formanka-change-me-in-production

# SMS vypnuto — zapnete az budete mit BulkGate/Twilio
SMS_ENABLED=false
SMS_PROVIDER=console

# Twilio (https://twilio.com) — funguje i s CZ čísly
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+420XXXXXXXXX

# BulkGate (https://bulkgate.com) — český SMS brána, vhodné pro CZ provoz
# SMS_PROVIDER=bulkgate
# BULKGATE_APPLICATION_ID=
# BULKGATE_APPLICATION_TOKEN=
# BULKGATE_SENDER=Na Formance
